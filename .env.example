# Credenciales del API (obligatorias en Vercel y en .env.local local)
INVENTORY_API_USERNAME=
INVENTORY_API_PASSWORD=

# Opcional: URL completa del endpoint (por defecto ya está definida en código)
# INVENTORY_API_URL=https://apiservices.lineadirectaec.com/APiPalet/api/Admin/ListSaldosBodegaMaestra

# El certificado TLS del host del API puede estar caducado; en ese caso poner 1
# (solo si la conexión falla por SSL; idealmente el proveedor renueva el certificado)
INVENTORY_TLS_INSECURE=1
