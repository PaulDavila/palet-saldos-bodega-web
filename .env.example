# Credenciales del API (NUNCA en el código del front; solo servidor)
#
# En Vercel: proyecto → Settings → Environment Variables
#   INVENTORY_API_USERNAME
#   INVENTORY_API_PASSWORD
#   INVENTORY_TLS_INSECURE=1   (si el certificado TLS del API está caducado)
# Marque Production (y Preview si usa deploys de preview). Luego redeploy.
#
# En local: copie este archivo a .env.local y rellene (no subir .env.local a git)
INVENTORY_API_USERNAME=
INVENTORY_API_PASSWORD=

# Opcional: URL completa del endpoint (por defecto ya está definida en código)
# INVENTORY_API_URL=https://apiservices.lineadirectaec.com/APiPalet/api/Admin/ListSaldosBodegaMaestra

# El certificado TLS del host del API puede estar caducado; en ese caso poner 1
# (solo si la conexión falla por SSL; idealmente el proveedor renueva el certificado)
INVENTORY_TLS_INSECURE=1

# Vercel Blob: crea un almacén en Vercel → Storage → Blob; el token se puede pegar aquí
# (en deploy en Vercel suele inyectarse solo al enlazar el store al proyecto).
# Sin esto, "Actualizar" trae datos pero no persisten entre visitas.
BLOB_READ_WRITE_TOKEN=
